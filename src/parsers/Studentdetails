// Delete cached model to always get fresh data
delete mongoose.models.Student;
const Student = mongoose.model('Student', studentSchema);
// ─── Session Store ────────────────────────────────────────────────
const sessions = {};

// ─── Safe value display ───────────────────────────────────────────
const EMPTY = ['nil', 'nill', 'null', 'undefined', 'n/a', 'no', '', 'none'];
const val = (v) => {
  if (v === null || v === undefined) return 'N/A';
  const s = v.toString().trim();
  if (s === '') return 'N/A';
  if (EMPTY.includes(s.toLowerCase())) return 'N/A';
  return s;
};

const fixPercent = (v) => {
  if (v === null || v === undefined) return 'N/A';
  const s = v.toString().trim().toUpperCase();
  if (s === 'ALL PASS' || s === 'ALLPASS') return 'ALL PASS';
  const n = parseFloat(s);
  if (isNaN(n)) return s;
  if (n > 0 && n < 2) return `${(n * 100).toFixed(1)}%`;
  return `${n}%`;
};

const fixIncome = (v) => {
  if (!v) return 'N/A';
  const s = v.toString().replace(/\s+/g, '').trim();
  const n = parseFloat(s);
  if (!isNaN(n)) return `Rs.${n.toLocaleString('en-IN')}/year`;
  return v.toString();
};

const short = (v, max = 32) => {
  const s = val(v);
  if (s === 'N/A') return s;
  return s.length > max ? s.substring(0, max - 2) + '..' : s;
};

const row = (label, value) => {
  const padded = label.padEnd(14, ' ');
  return `▪ ${padded}: ${value}`;
};

// ─── Fuzzy name search ────────────────────────────────────────────
// Finds students even with spelling mistakes using multiple strategies
async function fuzzySearch(searchName, year, dept) {
  const upper = searchName.trim().toUpperCase();

  // Strategy 1: Direct regex match (normal search)
let results = await Student.find({
  yearOfStudy: year,
  department:  dept,
  name: { $regex: searchName.trim(), $options: 'i' }
}).sort({ updatedAt: -1 }).lean();

  if (results.length > 0) return { results, matched: 'exact' };

  // Strategy 2: Search each word separately
  const words = upper.split(/\s+/).filter(w => w.length >= 2);
  if (words.length > 0) {
    const wordRegex = words.map(w => `(?=.*${w})`).join('');
    results = await Student.find({
      yearOfStudy: year,
      department:  dept,
      name: { $regex: wordRegex, $options: 'i' }
    }).sort({ updatedAt: -1 });
    if (results.length > 0) return { results, matched: 'words' };
  }

  // Strategy 3: First 3 chars of each word (handles spelling errors)
  const partials = upper.split(/\s+/)
    .filter(w => w.length >= 3)
    .map(w => w.substring(0, 3));

  if (partials.length > 0) {
    const allStudents = await Student.find({
      yearOfStudy: year,
      department:  dept,
    }).lean();

    // Score each student by how many partial matches they have
    const scored = allStudents
      .map(s => {
        const sName = (s.name || '').toUpperCase();
        const score = partials.filter(p => sName.includes(p)).length;
        return { s, score };
      })
      .filter(x => x.score > 0)
      .sort((a, b) => b.score - a.score)
      .map(x => x.s);

    if (scored.length > 0) return { results: scored, matched: 'fuzzy' };
  }

  return { results: [], matched: 'none' };
}

// ─── Update hint shown after student card ─────────────────────────
function updateHint(regNo) {
  return `\n✏️ *To update any field:*\n\`Update_${regNo}_FieldName into NewValue\`\n\n*Examples:*\n▪ \`Update_${regNo}_Section into B\`\n▪ \`Update_${regNo}_CGPA into 8.5\`\n▪ \`Update_${regNo}_Mobile into 9876543210\`\n▪ \`Update_${regNo}_BloodGroup into O+ve\``;
}

// ─── Extract Google Drive File ID ─────────────────────────────────
function getDriveFileId(photoField) {
  if (!photoField) return null;
  const str = photoField.toString().trim();
  const openMatch  = str.match(/open\?id=([-\w]+)/);
  if (openMatch)  return openMatch[1];
  const shareMatch = str.match(/\/d\/([-\w]+)/);
  if (shareMatch) return shareMatch[1];
  return null;
}

// ─── Send photo via Google Drive ──────────────────────────────────
async function sendPhotoToUser(to, fileId, caption) {
  const axios = require('axios');
  const fs    = require('fs');
  const path  = require('path');
  const os    = require('os');

  try {
    const urlsToTry = [
      `https://lh3.googleusercontent.com/d/${fileId}`,
      `https://drive.google.com/thumbnail?id=${fileId}&sz=w800`,
      `https://drive.google.com/uc?export=download&id=${fileId}&confirm=t`,
    ];

    let imageBuffer = null;
    for (const url of urlsToTry) {
      try {
        const res = await axios.get(url, {
          responseType: 'arraybuffer',
          timeout: 15000,
          maxRedirects: 10,
          headers: { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64)' },
        });
        if (res.data.byteLength > 10000) { imageBuffer = res.data; break; }
      } catch (_) { continue; }
    }

    if (!imageBuffer) { console.log(`⚠️ Could not download Drive photo: ${fileId}`); return false; }

    const tempPath = path.join(os.tmpdir(), `student_${fileId}_${Date.now()}.jpg`);
    fs.writeFileSync(tempPath, imageBuffer);
    await sendImage(to, tempPath, caption);
    try { fs.unlinkSync(tempPath); } catch (_) {}
    console.log(`📸 Photo sent to ${to}`);
    return true;
  } catch (err) {
    console.log(`⚠️ Drive photo failed: ${err.message}`);
    return false;
  }
}

