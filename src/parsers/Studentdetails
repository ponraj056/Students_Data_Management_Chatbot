// ─── Main Handler ─────────────────────────────────────────────────
async function handleStudentDetails(from, messageText) {
  const text = messageText.trim().toLowerCase();

  if (!sessions[from]) sessions[from] = { step: 'ask_year' };
  const session = sessions[from];

  // ── Step 1: Ask Year ──────────────────────────────────────────
  if (session.step === 'ask_year') {
    session.step = 'get_year';
    await sendTextMessage(from,
      `🎓 *Student Details Lookup*\n\nSelect year of study:\n\n1️⃣  1st Year\n2️⃣  2nd Year\n3️⃣  3rd Year\n4️⃣  4th Year\n\nReply with *1, 2, 3 or 4*`
    );
    return null;
  }

  // ── Step 2: Get Year ──────────────────────────────────────────
  if (session.step === 'get_year') {
    const yearMap = {
      '1': 1, '2': 2, '3': 3, '4': 4,
      '1st': 1, '2nd': 2, '3rd': 3, '4th': 4,
      'first': 1, 'second': 2, 'third': 3, 'fourth': 4
    };
    const year = yearMap[text];
    if (!year) {
      await sendTextMessage(from, `⚠️ Please reply with *1, 2, 3 or 4*`);
      return null;
    }

    session.year = year;
    session.step = 'get_dept';

    const depts = await Student.distinct('department', { yearOfStudy: year });
    if (depts.length === 0) {
      delete sessions[from];
      await sendTextMessage(from, `⚠️ No students found for *Year ${year}*.\nType *student details* to try again.`);
      return null;
    }

    session.deptOptions = depts.sort();
    const deptList = depts.sort().map((d, i) => `${i + 1}. ${d}`).join('\n');
    await sendTextMessage(from, `📚 *Year ${year} — Select Department:*\n\n${deptList}\n\nReply with *number* or *department name*`);
    return null;
  }

  // ── Step 3: Get Department ────────────────────────────────────
  if (session.step === 'get_dept') {
    const depts  = session.deptOptions;
    const num    = parseInt(text);
    let selected = null;

    if (!isNaN(num) && num >= 1 && num <= depts.length) {
      selected = depts[num - 1];
    } else {
      selected = depts.find(d => d.toLowerCase() === text || d.toLowerCase().includes(text));
    }

    if (!selected) {
      const deptList = depts.map((d, i) => `${i + 1}. ${d}`).join('\n');
      await sendTextMessage(from, `⚠️ Not found. Choose from:\n\n${deptList}`);
      return null;
    }

    session.department = selected;
    session.step       = 'get_name';
    await sendTextMessage(from, `🔍 *${selected} — Year ${session.year}*\n\nType student name or first few letters:`);
    return null;
  }

  // ── Step 4: Fuzzy Search & Return Full Details ────────────────
  if (session.step === 'get_name') {
    const searchName = messageText.trim();
    const year       = session.year;
    const dept       = session.department;
    delete sessions[from];

    // Fuzzy search — handles spelling mistakes
    const { results: allStudents, matched } = await fuzzySearch(searchName, year, dept);

    if (allStudents.length === 0) {
      await sendTextMessage(from,
        `❌ No student found with *"${searchName}"* in *${dept}, Year ${year}*.\n\n💡 Try first few letters of the name.\n\nType *student details* to search again.`
      );
      return null;
    }

    // Deduplicate by registerNumber — keep latest
    const seen = new Set();
    const students = allStudents.filter(s => {
      const key = s.registerNumber || s._id.toString();
      if (seen.has(key)) return false;
      seen.add(key);
      return true;
    });

    // Show fuzzy match notice if spelling was off
    if (matched === 'fuzzy') {
      await sendTextMessage(from,
        `🔍 Exact match not found for *"${searchName}"*.\nShowing closest matches:`
      );
    }

    // ── Single student ────────────────────────────────────────
    if (students.length === 1) {
      const s      = students[0];
      const fileId = getDriveFileId(s.photo);
      if (fileId) await sendPhotoToUser(from, fileId, `📸 ${val(s.name)} | ${val(s.registerNumber)}`);

      // Student card + update hint
      await sendTextMessage(from,
        formatStudent(s, 0, 1) +
        `\n\n${updateHint(val(s.registerNumber))}` +
        `\n\n📌 Type *student details* to search again.`
      );
      return null;
    }

    // ── Multiple students ─────────────────────────────────────
    const summary = students.map((s, i) =>
      `${i + 1}. *${val(s.name)}*  |  Reg: ${val(s.registerNumber)}  |  Sec: ${val(s.section)}`
    ).join('\n');

    await sendTextMessage(from,
      `👥 *${students.length} students found for "${searchName}":*\n\n${summary}\n\nSending full details below...`
    );

    for (let i = 0; i < students.length; i++) {
      const s      = students[i];
      const fileId = getDriveFileId(s.photo);
      if (fileId) await sendPhotoToUser(from, fileId, `📸 ${val(s.name)} | ${val(s.registerNumber)}`);

      // Each student card + their own update hint
      await sendTextMessage(from,
        formatStudent(s, i, students.length) +
        `\n\n${updateHint(val(s.registerNumber))}`
      );
    }

    await sendTextMessage(from,
      `📌 All *${students.length}* students shown above.\nType *student details* to search again.`
    );
    return null;
  }

  delete sessions[from];
  await sendTextMessage(from, `Something went wrong. Type *student details* to start again.`);
  return null;
}

function resetSession(from) {
  delete sessions[from];
}

module.exports = { handleStudentDetails, resetSession, sessions };