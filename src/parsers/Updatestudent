// ─── Protected fields ─────────────────────────────────────────────
const PROTECTED_FIELDS = ['registernumber', 'register_number', 'aadhaar', 'aadhaarnumber'];

// ─── Check if looks like a register number ────────────────────────
function isRegisterNumber(value) {
  // Register numbers are typically 12 digits like 922523205002
  return /^\d{10,15}$/.test(value.trim());
}

// ─── Detect if message is an update command ───────────────────────
function isUpdateCommand(message) {
  return /^update_/i.test(message.trim());
}

// ─── Cast value to correct type ───────────────────────────────────
function castValue(value, type) {
  if (type === 'number') {
    const num = parseFloat(value);
    return isNaN(num) ? value : num;
  }
  if (type === 'date') {
    // Try DD/MM/YYYY or D/M/YYYY format first (Indian format)
    const ddmmyyyy = value.match(/^(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{4})$/);
    if (ddmmyyyy) {
      const [, dd, mm, yyyy] = ddmmyyyy;
      const d = new Date(`${yyyy}-${mm.padStart(2,'0')}-${dd.padStart(2,'0')}`);
      if (!isNaN(d.getTime())) return d;
    }
    // Try YYYY-MM-DD or other standard formats
    const d = new Date(value);
    return isNaN(d.getTime()) ? value : d;
  }
  return value;
}

function escapeRegex(str) {
  return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

// ─── Main Update Handler ──────────────────────────────────────────
async function handleUpdateCommand(from, message) {
  const text = message.trim();

  // Format: Update_PART1_PART2 into NewValue
  const regex = /^update_([a-zA-Z0-9_@.]+)_(.+?)\s+into\s+(.+)$/i;
  const match = text.match(regex);

  if (!match) {
    return `⚠️ *Invalid format!*\n\nTwo ways to update:\n\n*1. By Register Number (recommended):*\n\`Update_RegNo_FieldName into NewValue\`\n\nExample:\n• \`Update_922523205002_Section into B\`\n• \`Update_922523205002_CGPA into 8.5\`\n• \`Update_922523205002_Mobile into 9876543210\`\n\n*2. By Old Value:*\n\`Update_FieldName_OldValue into NewValue\`\n\nExample:\n• \`Update_CGPA_7.52 into 8.5\`\n• \`Update_Email_old@gmail.com into new@gmail.com\``;
  }

  const part1    = match[1].trim(); // RegNo OR FieldName
  const part2    = match[2].trim(); // FieldName OR OldValue
  const newValue = match[3].trim();

  try {
    // ── FORMAT 2: Update by Register Number ──────────────────
    // Update_922523205002_Section into B
    if (isRegisterNumber(part1)) {
      const regNo     = part1;
      const fieldKey  = part2.toLowerCase().replace(/\s+/g, '');

      if (PROTECTED_FIELDS.includes(fieldKey)) {
        return `🔒 *"${part2}" cannot be updated.*\nThis field is protected.`;
      }

      const fieldInfo = FIELD_MAP[fieldKey];
      if (!fieldInfo) {
        return `❓ *Unknown field: "${part2}"*\n\nCommon fields:\nSection, CGPA, Mobile, Email, Address,\nArrear, BloodGroup, FatherMobile,\nMotherMobile, PlacementStatus, Company`;
      }

      const student = await Student.findOne({
        registerNumber: { $regex: new RegExp(`^${escapeRegex(regNo)}$`, 'i') }
      });

      if (!student) {
        return `❌ *No student found* with Register Number *${regNo}*\n\nCheck the register number and try again.`;
      }

      const castedValue = castValue(newValue, fieldInfo.type);
      await Student.updateOne(
        { registerNumber: { $regex: new RegExp(`^${escapeRegex(regNo)}$`, 'i') } },
        { $set: { [fieldInfo.field]: castedValue } }
      );

      return `✅ *Update Successful!*

👤 *Student* : ${student.name}
🔢 *Reg No*  : ${student.registerNumber}
📝 *Field*   : ${part2}
🟢 *New Value*: ${newValue}

🕒 ${new Date().toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' })}`;
    }

    // ── FORMAT 1: Update by Old Value ────────────────────────
    // Update_Section_A into B
    const fieldKey = part1.toLowerCase().replace(/\s+/g, '');

    if (PROTECTED_FIELDS.includes(fieldKey)) {
      return `🔒 *"${part1}" cannot be updated.*\nThis field is protected.`;
    }

    const fieldInfo = FIELD_MAP[fieldKey];
    if (!fieldInfo) {
      return `❓ *Unknown field: "${part1}"*\n\nCommon fields:\nSection, CGPA, Mobile, Email, Address,\nArrear, BloodGroup, FatherMobile,\nMotherMobile, PlacementStatus, Company`;
    }

    const { field, type } = fieldInfo;
    const oldValue = part2;

    // Search by old value (including null)
    let query;
    if (oldValue.toLowerCase() === 'null' || oldValue.toLowerCase() === 'n/a') {
      // Match null, empty, or N/A values
      query = {
        $or: [
          { [field]: null },
          { [field]: '' },
          { [field]: { $regex: /^n\/a$/i } },
          { [field]: { $exists: false } }
        ]
      };
    } else {
      query = { [field]: { $regex: new RegExp(`^${escapeRegex(oldValue)}$`, 'i') } };
    }

    const students = await Student.find(query);

    if (students.length === 0) {
      return `❌ *No student found* with *${part1}* = *"${oldValue}"*\n\n💡 *Tip: Use register number instead:*\n\`Update_RegNo_${part1} into ${newValue}\`\n\nExample:\n\`Update_922523205002_${part1} into ${newValue}\``;
    }

    const castedNewValue = castValue(newValue, type);
    const result = await Student.updateMany(query, { $set: { [field]: castedNewValue } });
    const updatedNames = students.map(s => `• ${s.name} (${s.registerNumber || 'N/A'})`).join('\n');

    return `✅ *Update Successful!*

📝 *Field*    : ${part1}
🔴 *Old Value*: ${oldValue}
🟢 *New Value*: ${newValue}

👤 *Updated ${result.modifiedCount} student(s):*
${updatedNames}

🕒 ${new Date().toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' })}`;

  } catch (err) {
    console.error('Update error:', err);
    return `⚠️ *Update failed!*\nError: ${err.message}\n\nPlease try again.`;
  }
}

module.exports = { handleUpdateCommand, isUpdateCommand };